[Unit]
Description=Remount the squashfs and ubi volumes after a reboot
Wants=xyz.openbmc_project.Software.Host.Updater.service
Before=xyz.openbmc_project.Software.Host.Updater.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/obmc-flash-bios ubiremount

[Install]
WantedBy=multi-user.target
